---
import { clanData } from "../data/clan-data";

const activeMembers = clanData.members.filter((member) => !member.isFormer);

const rolePriority: Record<string, number> = {
  LIDER: 1,
  COLIDER: 2,
  CAPITAN: 3,
  MIEMBRO: 4,
  RECLUTADOR: 4,
  ADMIN: 5,
};

const sortedMembers = [...activeMembers].sort((a, b) => {
  const roleDiff = (rolePriority[a.role] ?? 99) - (rolePriority[b.role] ?? 99);
  if (roleDiff !== 0) return roleDiff;
  return a.username.localeCompare(b.username, "es");
});

const getRoleBadge = (role: string) => {
  const colors: Record<string, string> = {
    LIDER: "bg-red-900/60 text-red-200 border-red-700/60",
    COLIDER: "bg-red-950/60 text-red-300 border-red-900/70",
    CAPITAN: "bg-[#470A00]/70 text-red-100 border-red-900/70",
    RECLUTADOR: "bg-[#2b0a0a]/80 text-gray-100 border-red-900/60",
    MIEMBRO: "bg-[#1f0707]/80 text-gray-200 border-gray-700/70",
    ADMIN: "bg-[#3a0f0f]/80 text-red-100 border-red-800/80",
  };

  return colors[role] ?? "bg-gray-900/80 text-gray-200 border-gray-700/70";
};
---

<section id="miembros" class="relative py-20 px-4 md:px-8 overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-5xl md:text-6xl font-black mb-4">
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-700 via-red-600 to-red-500">
          Miembros del Clan
        </span>
      </h2>
      <div class="w-24 h-1 bg-gradient-to-r from-red-800 to-red-600 mx-auto rounded-full mb-4"></div>
      <p class="text-gray-400 text-lg">{activeMembers.length} miembros activos</p>
    </div>

    <div class="mb-8 max-w-3xl mx-auto">
      <label for="member-search" class="text-sm text-gray-400 mb-2 block">Buscar por nombre</label>
      <input
        id="member-search"
        type="search"
        placeholder="Escribe un nombre..."
        class="w-full rounded-xl border border-red-900/70 bg-black/60 px-4 py-3 text-white placeholder:text-gray-500 focus:outline-none focus:ring-2 focus:ring-red-800/70"
      />
      <p id="member-counter" class="mt-2 text-xs text-gray-500">Mostrando {sortedMembers.length} miembros</p>
    </div>

    <div class="member-scroll rounded-2xl border border-red-900/60 bg-black/45 p-4 md:p-6">
      <div id="members-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {
          sortedMembers.map((member) => (
            <article
              class="member-card group relative rounded-xl border border-gray-800/80 bg-gradient-to-b from-[#130505] to-black/90 p-4 hover:border-red-700/60 transition-all duration-300"
              data-name={member.username.toLowerCase()}
            >
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-xl bg-gradient-to-br from-red-900/15 to-transparent" />
              <div class="relative z-10 flex items-start gap-3">
                <img
                  src={member.avatar}
                  alt={member.username}
                  class="w-14 h-14 rounded-full border border-red-900/70 object-cover"
                />

                <div class="min-w-0 flex-1">
                  <h3 class="text-white font-bold truncate">{member.username}</h3>
                  <div class="mt-1 flex flex-wrap items-center gap-2">
                    <span
                      class={`text-[11px] font-bold uppercase tracking-wider border px-2 py-1 rounded ${getRoleBadge(member.role)}`}
                    >
                      {member.role}
                    </span>
                    {member.captainSpecialty && (
                      <span class="text-[11px] font-semibold uppercase tracking-wider border border-red-900/70 bg-[#2a0b0b]/70 text-red-200 px-2 py-1 rounded">
                        {member.captainSpecialty}
                      </span>
                    )}
                  </div>
                  <div class="mt-3">
                    <p class="text-[11px] text-gray-500 mb-1">Contribucion</p>
                    <div class="w-full h-1.5 rounded-full bg-[#180606] overflow-hidden">
                      <div
                        class="h-full bg-gradient-to-r from-red-900 via-red-700 to-[#470A00]"
                        style={{ width: `${Math.min((member.contributions / 2000) * 100, 100)}%` }}
                      />
                    </div>
                    <p class="text-[11px] text-red-300 mt-1">{member.contributions} pts</p>
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
      <p id="member-empty" class="hidden text-center text-gray-400 py-12">No hay resultados para esa busqueda.</p>
    </div>
  </div>
</section>

<script>
  const searchInput = document.querySelector("#member-search");
  const cards = Array.from(document.querySelectorAll(".member-card"));
  const counter = document.querySelector("#member-counter");
  const emptyState = document.querySelector("#member-empty");

  const applyFilter = () => {
    const query = (searchInput?.value ?? "").trim().toLowerCase();
    let visible = 0;

    for (const card of cards) {
      const name = card.dataset.name ?? "";
      const matched = name.includes(query);
      card.classList.toggle("hidden", !matched);
      if (matched) visible += 1;
    }

    if (counter) {
      counter.textContent = `Mostrando ${visible} miembros`;
    }

    if (emptyState) {
      emptyState.classList.toggle("hidden", visible !== 0);
    }
  };

  searchInput?.addEventListener("input", applyFilter);
</script>

<style>
  section {
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.65) 0%, rgba(24, 5, 5, 0.65) 100%);
    border-top: 1px solid rgba(120, 10, 10, 0.45);
  }

  .member-scroll {
    max-height: 760px;
    overflow-y: auto;
  }

  .member-scroll::-webkit-scrollbar {
    width: 10px;
  }

  .member-scroll::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, rgba(120, 15, 15, 0.9), rgba(71, 10, 0, 0.85));
    border-radius: 999px;
  }
</style>
