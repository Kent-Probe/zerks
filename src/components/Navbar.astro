---
// Navbar Component
import { clanData } from "../data/clan-data";

interface Props {
  currentPage?: string;
}

const { currentPage = "inicio" } = Astro.props;

const navItems = [
  { label: "Inicio", href: "#inicio", id: "inicio" },
  { label: "Clan", href: "#clan", id: "clan" },
  { label: "Jerarquía", href: "#jerarquia", id: "jerarquia" },
  { label: "Miembros", href: "#miembros", id: "miembros" },
  { label: "Aportaciones", href: "#aportaciones", id: "aportaciones" },
  { label: "Proyectos", href: "#proyectos", id: "proyectos" },
];
---

<nav
  class="fixed top-0 w-full z-50 bg-gradient-to-b from-black to-transparent backdrop-blur-sm border-b border-red-900/60"
>
  <div class="max-w-7xl mx-auto px-4 py-4">
    <div class="flex items-center justify-between">
      {/* Logo */}
      <div class="flex items-center gap-2 group cursor-pointer">
        <img src="logo_zerks.png" alt="Clan Logo" class="w-10 h-10 object-cover" />
      </div>

      {/* Desktop Menu */}
      <div class="hidden md:flex gap-1">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class={`px-4 py-2 rounded-lg font-medium transition-all duration-300 text-sm ${
                currentPage === item.id
                  ? "bg-gradient-to-r from-red-800 to-red-600 text-white shadow-lg shadow-red-900/60"
                  : "text-gray-300 hover:text-red-300 hover:bg-red-900/20"
              }`}
            >
              {item.label}
            </a>
          ))
        }
      </div>

      {/* Join Button */}
      <a
        href={clanData.discordInvite}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-block px-6 py-2 bg-gradient-to-r from-red-800 to-red-600 text-white rounded-lg font-bold hover:shadow-lg hover:shadow-red-900/60 transition-all duration-300 transform hover:scale-105"
      >
        Unirse
      </a>

      {/* Mobile Menu Button */}
      <button class="md:hidden text-red-300 hover:text-red-200 transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>
</nav>

<style>
  nav {
    --tw-shadow: 0 10px 30px rgba(220, 38, 38, 0.2);
  }
</style>
